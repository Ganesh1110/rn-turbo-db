{
  "name": "react-native-turbo-db",
  "version": "1.0.0",
  "description": "High-performance JSI-driven embedded key-value database for React Native with encryption, WAL logging, B+tree indexing, and SSR/isomorphic support. Fast AsyncStorage alternative.",
  "main": "./lib/module/index.js",
  "exports": {
    ".": {
      "react-native": {
        "types": "./lib/typescript/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "browser": {
        "types": "./lib/typescript/src/index.web.d.ts",
        "default": "./lib/module/index.web.js"
      },
      "types": "./lib/typescript/src/index.d.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "scripts",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!android/generated",
    "!ios/generated",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "clean": "del-cli android/build lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "release": "release-it --only-version",
    "web": "vite",
    "build:web": "vite build"
  },
  "keywords": [
    "react-native",
    "jsi",
    "turbo-module",
    "database",
    "secure-database",
    "encrypted-storage",
    "key-value-store",
    "kv-store",
    "embedded-database",
    "local-database",
    "performance",
    "ssr",
    "isomorphic",
    "web",
    "asyncstorage",
    "encryption",
    "crypto",
    "libsodium",
    "xchacha20",
    "keychain",
    "keystore",
    "b-tree",
    "bplustree",
    "indexed",
    "mmap",
    "wal",
    "write-ahead-log",
    "react-native-storage",
    "mobile-database"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ganesh1110/react-native-turbo-db.git"
  },
  "author": "Ganesh Jayaprakash <ganesh@turbo-db.io> (https://github.com/ganeshjayaprakash)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ganesh1110/react-native-turbo-db/issues"
  },
  "homepage": "https://github.com/Ganesh1110/react-native-turbo-db#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.0.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "commitlint": "^20.5.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "react-native-web": "~0.21.1",
    "release-it": "^19.2.4",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ],
      "codegen"
    ]
  },
  "codegenConfig": {
    "name": "TurboDBSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    },
    "android": {
      "javaPackageName": "com.turbodb"
    },
    "includesGeneratedCode": false
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "cpp",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it",
      "vite"
    ],
    "version": "0.61.0"
  }
}
